/* Globals */
QWidget {
    font-family: 'Ubuntu', sans-serif;
    color: hsl(0, 0%, 95%);
}

QMainWindow {
    background-color: hsl(0, 0%, 5%);
}

/* Menu Bar */
QMenuBar {
    font-size: 10pt;
    spacing: 0px;
}

QMenuBar::item {
    border-top: 0;
    border-left: 0;
    border-right: 0;
    border-bottom: 1px solid lightgray;
    padding: 3px 6px;
}

QMenuBar::item:pressed {
    background-color: hsl(0, 0%, 20%);
}

QPushButton#selectProjectButton {
    padding: 15px 25px;
    font-size: 18px;
}

QHLine {
    color: lightgray;
}

QLabel#noProjectSelectedLabel {
    font-size: 48px;
    color: hsl(0, 0%, 20%);
}